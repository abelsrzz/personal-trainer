telegram:
  bot_token: 123456789:replace_me
  chat_id: 123456789
  caption_prefix: Running Coach
  allowed_chat_ids:
    - 123456789

notifications:
  enabled: true
  timezone: Europe/Madrid
  morning_brief_time: "07:30"
  quiet_hours_start: "23:00"
  quiet_hours_end: "07:00"
  status_chat_ids:
    - 123456789

opencode_remote:
  enabled: true
  server_url: http://127.0.0.1:4096
  project_dir: /absolute/path/to/personal-trainer
  session_store: telegram/opencode_sessions.json
  timeout_s: 1800
  allow_commit: true
  allow_push: true
  # Telegram bot runs unattended and must be able to edit training files without
  # waiting for an interactive approval prompt.
  dangerously_skip_permissions: true
  local_retry_timeout_s: 900
  model: openai/gpt-5.4
  # `minimal` keeps Telegram replies snappy; heavier variants are better left for
  # offline planning pipelines.
  variant: minimal
  max_response_chars: 12000
  require_confirmation_patterns:
    - "git push --force"
    - "reset --hard"
    - "rm -rf"
    - "borra todo"
    - "elimina todo"
