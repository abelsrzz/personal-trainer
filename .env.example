# Copy to .env and fill in. Never commit .env.

# PostgreSQL
POSTGRES_DB=personal_trainer
POSTGRES_USER=personal_trainer
POSTGRES_PASSWORD=change-me-strong
DATABASE_URL=postgresql://personal_trainer:change-me-strong@db:5432/personal_trainer

# Storage backend: sql enables the dockerized DB; file keeps legacy behavior.
STORAGE_BACKEND=sql
RECONCILE_INTERVAL_SECONDS=300

# Web
RUNNING_WEB_USERNAME=abel
RUNNING_WEB_PASSWORD=change-me
RUNNING_WEB_SECRET=change-me-too
RUNNING_WEB_PORT=8090
RUNNING_WEB_V2_GARMIN_AUTO_SYNC=1

# Garmin
GARMIN_EMAIL=your.email@example.com
GARMIN_PASSWORD=your_password
GARMIN_TOKEN_STORE=/home/app/.garminconnect
POST_WORKOUT_REFRESH_INTERVAL_SECONDS=300

# Telegram
TELEGRAM_BOT_TOKEN=123456789:replace_me
TELEGRAM_CHAT_ID=123456789
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# OpenCode
OPENCODE_SERVER_URL=http://opencode:4096
OPENCODE_PROJECT_DIR=/app
OPENCODE_SESSION_STORE=telegram/opencode_sessions.json
OPENCODE_REMOTE_ENABLED=1
OPENCODE_MODEL=openai/gpt-5.4
OPENCODE_VARIANT=minimal
OPENCODE_TIMEOUT_S=1800
OPENCODE_MAX_RESPONSE_CHARS=12000
OPENCODE_REQUIRE_CONFIRMATION_PATTERNS=
OPENCODE_ALLOW_COMMIT=1
OPENCODE_ALLOW_PUSH=1
OPENCODE_DANGEROUSLY_SKIP_PERMISSIONS=0
XDG_DATA_HOME=/tmp/opencode-data
XDG_CONFIG_HOME=/tmp/opencode-config
OPENAI_API_KEY=
GEMINI_API_KEY=
